# Database
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/ecommerce?retryWrites=true&w=majority"

# Auth
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-long"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (plug & play — leave empty to disable payments)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Cloudinary (plug & play — leave empty to disable uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Resend (plug & play — leave empty to disable emails)
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# Commerce defaults
TAX_RATE="0.2"
SHIPPING_FLAT_RATE="5.99"
FREE_SHIPPING_THRESHOLD="100"

# WhatsApp (optional — fixed button on screen)
NEXT_PUBLIC_WHATSAPP_NUMBER="33612345678"

# Seed admin password (dev only — never commit real passwords)
ADMIN_SEED_PASSWORD="ChangeMe123!@#"
